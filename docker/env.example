# Copy to the repo root as `.env` for docker compose:
#   cp docker/env.example .env

# Cursor backend transport (required for vision/PDF on direct chat path).
# Values from https://github.com/standardagents/composer-api/issues/13#issuecomment-4568422887
CURSOR_BACKEND_BASE_URL=https://api2.cursor.sh
CURSOR_CHAT_ENDPOINT=/aiserver.v1.AiService/StreamChat
CURSOR_LOCAL_AGENT_ENDPOINT=/agent.v1.AgentService/Run

# Optional shared secret between the API and bridge containers.
CURSOR_SDK_BRIDGE_TOKEN=

# Host port published for the OpenAI-compatible API.
CURSOR_API_PORT=8787

# Project directory mounted into the bridge for agent file tools.
WORKSPACE=.
